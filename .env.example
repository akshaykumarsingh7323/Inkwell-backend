# =============================================================
# InkWell Backend - Environment Configuration Template
# =============================================================

# --- Auth Service DB ---
AUTH_DB_URL=jdbc:mysql://localhost:3306/auth_db?createDatabaseIfNotExist=true
AUTH_DB_USERNAME=
AUTH_DB_PASSWORD=

# --- Post Service DB ---
POST_DB_URL=jdbc:mysql://localhost:3306/post_db?createDatabaseIfNotExist=true
POST_DB_USERNAME=
POST_DB_PASSWORD=

# --- Comment Service DB ---
COMMENT_DB_URL=jdbc:mysql://localhost:3306/comment_db?createDatabaseIfNotExist=true
COMMENT_DB_USERNAME=
COMMENT_DB_PASSWORD=

# --- Category Service DB ---
CATEGORY_DB_URL=jdbc:mysql://localhost:3306/category_db?createDatabaseIfNotExist=true
CATEGORY_DB_USERNAME=
CATEGORY_DB_PASSWORD=

# --- Media Service DB ---
MEDIA_DB_URL=jdbc:mysql://localhost:3306/media_db?createDatabaseIfNotExist=true
MEDIA_DB_USERNAME=
MEDIA_DB_PASSWORD=

# --- Newsletter Service DB ---
NEWSLETTER_DB_URL=jdbc:mysql://localhost:3306/newsletter_db?createDatabaseIfNotExist=true
NEWSLETTER_DB_USERNAME=
NEWSLETTER_DB_PASSWORD=

# --- Notification Service DB ---
NOTIFICATION_DB_URL=jdbc:mysql://localhost:3306/notification_db?createDatabaseIfNotExist=true
NOTIFICATION_DB_USERNAME=
NOTIFICATION_DB_PASSWORD=

# --- Payment Service DB ---
PAYMENT_DB_URL=jdbc:mysql://localhost:3306/payment_db?createDatabaseIfNotExist=true
PAYMENT_DB_USERNAME=
PAYMENT_DB_PASSWORD=

# =============================================================
# INFRASTRUCTURE
# =============================================================
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
REDIS_PASSWORD=

EUREKA_SERVER_URL=http://localhost:8761/eureka/

RABBITMQ_HOST=localhost
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=

# =============================================================
# JWT CONFIG
# =============================================================
JWT_SECRET=
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# =============================================================
# OAUTH2 CONFIG
# =============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH2_REDIRECT_URI=http://localhost:4200/login-success

# =============================================================
# MAIL CONFIG
# =============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# =============================================================
# AWS S3 CONFIG
# =============================================================
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=inkwell-media-post-storage

# =============================================================
# SERVER PORTS
# =============================================================
SERVER_PORT_AUTH=8081
SERVER_PORT_POST=8082
SERVER_PORT_COMMENT=8083
SERVER_PORT_CATEGORY=8084
SERVER_PORT_MEDIA=8085
SERVER_PORT_NEWSLETTER=8086
SERVER_PORT_NOTIFICATION=8087
SERVER_PORT_PAYMENT=8089
SERVER_PORT_WEB=8090
MEDIA_LOCAL_PATH=

# =============================================================
# RAZORPAY CONFIG
# =============================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# =============================================================
# TWILIO CONFIG
# =============================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# =============================================================
# SONARQUBE CONFIG
# =============================================================
SONAR_TOKEN=
